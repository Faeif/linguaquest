# ============================
# LinguaQuest — Environment Variables
# Copy this file to .env.local and fill in values
# ============================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── AI Models ─────────────────────────────────────────
# 1. DeepSeek V3.2 — Chinese Specialist (parse, card gen, essay grader)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 2. Qwen3 — Thai Explainer (natural Thai explanations)
ALIBABA_CLOUD_API_KEY=
QWEN3_CHAT_MODEL=qwen-max
QWEN3_CHAT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 3. Qwen3-ASR — Speech-to-Text (Chinese, free open-source)
# Options: Self-host (free) OR Alibaba Cloud API
QWEN3_ASR_MODEL=qwen3-asr-flash
# QWEN3_ASR_BASE_URL=  # Only needed if using Alibaba Cloud API

# 4. SpeechSuper — Pronunciation & Tone Assessment
SPEECHSUPER_APP_KEY=
SPEECHSUPER_SECRET_KEY=
SPEECHSUPER_BASE_URL=https://api.speechsuper.com

# 5. Gemini Flash — Content Moderator only (community uploads)
GEMINI_API_KEY=

# ─── Cache + Queue ─────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
QSTASH_URL=
QSTASH_TOKEN=

# Rate Limits (requests per day per user, enforced via Redis)
RATE_LIMIT_FREE_AI_COMPANION=10
RATE_LIMIT_FREE_SPEAKING=5
RATE_LIMIT_FREE_ESSAY=3
RATE_LIMIT_PRO_AI_COMPANION=100
RATE_LIMIT_PRO_SPEAKING=30
RATE_LIMIT_PRO_ESSAY=30

# ─── Storage ───────────────────────────────────────────
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=linguaquest-media
CLOUDFLARE_R2_ENDPOINT=

# ─── Communication ─────────────────────────────────────
RESEND_API_KEY=

# ─── Payment ───────────────────────────────────────────
OMISE_PUBLIC_KEY=
OMISE_SECRET_KEY=

# ─── Monitoring ────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── App ───────────────────────────────────────────────
NEXTAUTH_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000

