{
  "name": "linguaquest",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "prepare": "husky",
    "hsk:generate": "python3 scripts/fix-thai-meanings.py && node --experimental-strip-types scripts/generate-hsk-data.mts",
    "hsk:thai": "node --experimental-strip-types scripts/generate-thai-meanings.mts",
    "hsk:sentences": "node --experimental-strip-types scripts/generate-sentences.mts",
    "hsk:pos": "node --experimental-strip-types scripts/generate-pos-tags.mts",
    "hsk:all": "pnpm hsk:thai && pnpm hsk:sentences && pnpm hsk:pos && pnpm hsk:generate",
    "audio:upload": "node --experimental-strip-types scripts/upload-audio-r2.mts"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "latest",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "volta": {
    "node": "20.11.0",
    "pnpm": "9.0.0"
  }
}
